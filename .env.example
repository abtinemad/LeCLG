# .env.example — copier en .env et remplir. Ne jamais committer le .env réel.

# --- Secrets (obligatoires) ---
# Clé API Google Gemini (evals enrich_*/eval_* gérées par server.ts)
GEMINI_API_KEY=
# Service-role key Supabase (écritures serveur, ne JAMAIS exposer au front)
SUPABASE_SERVICE_KEY=
# Mot de passe d'accès au panneau admin (vérifié côté serveur)
ADMIN_PASSWORD=
# Secret partagé server.ts <-> worker Cloudflare (en-tête X-Internal-Secret).
# DOIT être identique au secret configuré sur le worker. Si vide, le worker
# renvoie 403 et le chat ne fonctionne pas.
INTERNAL_SECRET=
# Secret serveur mêlé au hachage des codes d'accès à 6 chiffres. Doit être
# une longue valeur aléatoire, gardée secrète et stable (la changer invalide
# tous les codes existants). Ex. : openssl rand -hex 32
ACCESS_PEPPER=

# --- Infrastructure ---
# URL du projet Supabase (un défaut est codé dans server.ts mais le poser
# ici explicitement évite toute ambiguïté entre environnements)
SUPABASE_URL=
# URL du worker Cloudflare qui relaie chat/eval vers l'API Anthropic
CF_WORKER_URL=

# --- Dev (optionnel) ---
# "production" en prod ; sinon Vite sert le front en mode dev
NODE_ENV=
# Mettre à "1" pour désactiver le hot-reload Vite en développement
DISABLE_HMR=